# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.100.81

# Database (Development)
DATABASE_URL=sqlite:///db.sqlite3

# API Configuration
API_BASE_URL=http://localhost:8000/api
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8082,exp://localhost:8082,exp://192.168.100.81:8082

# Firebase (Get from Firebase Console)
FIREBASE_CREDENTIALS_PATH=path/to/serviceAccountKey.json

# Stripe (Get from Stripe Dashboard - test keys for development)
STRIPE_SECRET_KEY=sk_test_your_test_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Free AI APIs (Sign up for free tiers)
# Google Gemini API - https://makersuite.google.com
GEMINI_API_KEY=AIza...

# Hugging Face API - https://huggingface.co/join
HUGGINGFACE_API_KEY=hf_...

# Weather API - https://openweathermap.org (free tier)
OPENWEATHER_API_KEY=your_openweather_api_key_here
